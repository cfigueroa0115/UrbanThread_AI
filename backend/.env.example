DATABASE_URL="postgresql://postgres:postgres@localhost:5432/urbanthread_ai?schema=public"
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=1h

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_BLOCK_MINUTES=15

# Email / SMTP
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@urbanthread.ai

# OpenAI (optional)
OPENAI_API_KEY=

# Google Gemini AI (primary AI provider for chatbot)
GEMINI_API_KEY=

# WhatsApp / Meta Cloud API (optional)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=urbanthread-whatsapp-verify-token

# n8n
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000
