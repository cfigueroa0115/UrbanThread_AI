{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@shared/types/*": ["../shared/types/*"],
      "@shared/schemas/*": ["../shared/schemas/*"],
      "@shared/constants/*": ["../shared/constants/*"],
      "@shared/utils/*": ["../shared/utils/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
